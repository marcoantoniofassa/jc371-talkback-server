# YUV API (Jimi/Concox cgv)
CGV_JIMI_API_KEY=cole_token_aqui
YUV_API_BASE_URL=https://api.cloud-services.yuv.com.br

# Endereco publico do MediaMTX que a camera vai consumir.
# No Railway: setar pro hostname do TCP proxy gerado no painel (ex: jc371-talkback.up.railway.app).
# Local: ngrok tcp 1935 e usar o host gerado.
RTMP_PUBLIC_HOST=
RTMP_PUBLIC_PORT=1935

# HTTP API
PORT=3000

# TTS
EDGE_TTS_VOICE=pt-BR-ThalitaNeural

# Default duration (segundos) entre startTalkURL e stopTalkURL
DEFAULT_TALK_DURATION_SEC=8
